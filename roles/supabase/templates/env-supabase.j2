############
# Secrets
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
############

POSTGRES_PASSWORD={{ postgres_db_pwd }}
JWT_SECRET={{ sb_jwt_secret }}
ANON_KEY={{ sb_anon_key }}
SERVICE_ROLE_KEY={{ sb_service_role_key }}
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
SECRET_KEY_BASE={{ secret_key_base }}
VAULT_ENC_KEY=your-encryption-key-32-chars-min
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-public
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-private
S3_PROTOCOL_ACCESS_KEY_ID=change-me
S3_PROTOCOL_ACCESS_KEY_SECRET=change-me

############
# URLs
############

SUPABASE_PUBLIC_URL={{ api_external_url }}
API_EXTERNAL_URL={{ api_external_url }}

############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Supavisor
############

POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=your-tenant-id
POOLER_DB_POOL_SIZE=5

############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
STUDIO_PORT=3000
OPENAI_API_KEY={{ openai_api_key }}

############
# Auth
############

SITE_URL={{ site_url }}
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

MAILER_SUBJECTS_INVITE="{% raw %}{{.Data.EmailTemplate.Invite.Title}}{% endraw %}"
MAILER_SUBJECTS_CONFIRMATION="{% raw %}{{.Data.EmailTemplate.Confirmation.Title}}{% endraw %}"
MAILER_SUBJECTS_RECOVERY="{% raw %}{{.Data.EmailTemplate.Recovery.Title}}{% endraw %}"
MAILER_SUBJECTS_EMAIL_CHANGE="{% raw %}{{.Data.EmailTemplate.EmailChange.Title}}{% endraw %}"

MAILER_TEMPLATES_RECOVERY={{ api_external_url }}/storage/v1/object/public/templates/reset_password.html
MAILER_TEMPLATES_CONFIRMATION={{ api_external_url }}/storage/v1/object/public/templates/email_confirmation.html
MAILER_TEMPLATES_EMAIL_CHANGE={{ api_external_url }}/storage/v1/object/public/templates/email_change.html
MAILER_TEMPLATES_INVITE={{ api_external_url }}/storage/v1/object/public/templates/email_invite.html

PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRED_CHARACTERS=abcdefghijklmnopqrstuvwxyz:ABCDEFGHIJKLMNOPQRSTUVWXYZ:0123456789:!"#$%&'()*+,-./;<=>?@[\]^_`{|}~
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL={{ smtp_admin_email }}
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port }}
SMTP_USER={{ smtp_user }}
SMTP_PASS={{ smtp_password }}
SMTP_SENDER_NAME={{ smtp_sender_name }}
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

REDIRECT_URI={{ api_external_url }}/auth/v1/callback
ENABLE_GOOGLE_SIGNUP=true
GOOGLE_CLIENT_ID={{ google_client_id }}
GOOGLE_SECRET={{ google_secret }}
ENABLE_AZURE_SIGNUP=true
AZURE_CLIENT_ID={{ azure_client_id }}
AZURE_SECRET={{ azure_secret }}
GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_ENABLED=true
GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_URI="pg-functions://postgres/private/custom_access_token_hook"
GOTRUE_SECURITY_REFRESH_TOKEN_ROTATION_ENABLED=true
MFA_ENABLED=false

############
# Storage
############

GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub

############
# Functions
############

FUNCTIONS_VERIFY_JWT=false

############
# API
############

PGRST_DB_SCHEMAS=private,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# Analytics
############

DOCKER_SOCKET_LOCATION=/var/run/docker.sock

############
# API Gateway
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

############
# imgproxy
############

IMGPROXY_AUTO_WEBP=true
